# Supabase (auto-injected by Lovable Cloud — do not set manually)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Lovable AI Gateway (required for AI features — auto-provisioned)
LOVABLE_API_KEY=

# Google Maps (optional — used for address autocomplete in client forms)

# AgentSync (optional — used for NPN/license lookups in contracting)
AGENTSYNC_API_KEY=

# ── Stripe billing (Monetization v2.1) ────────────────────────────────────────
# Create the products/prices in the Stripe dashboard, then fill these in.
# Billing surfaces show a "not configured" state until STRIPE_SECRET_KEY is set.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (price_...) for each product:
STRIPE_AGENCY_PLAN_PRICE_ID=          # agency_plan_base — $199/mo, org-level
STRIPE_SEAT_OVERAGE_PRICE_ID=         # agency_seat_overage — $20/agent/mo (metered)
STRIPE_NOVA_PRO_AGENT_PRICE_ID=       # nova_pro_agent — $49/mo, agent personal
STRIPE_NOVA_PRO_AGENCY_SEAT_PRICE_ID= # nova_pro_agency_seat — $49/mo, org-assigned
STRIPE_SOLO_PLAN_PRICE_ID=            # solo_agent_plan — $79/mo
STRIPE_WHITE_LABEL_SETUP_PRICE_ID=    # white_label_setup — $999 one-time
STRIPE_WHITE_LABEL_MONTHLY_PRICE_ID=  # white_label_monthly — $499/mo
# Absolute origin used in Stripe redirect URLs:
APP_ORIGIN=https://useagentcloud.com
